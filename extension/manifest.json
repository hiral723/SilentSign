{
  "manifest_version": 3,
  "name": "SilentSign",
  "version": "1.0.0",
  "description": "Real-time sign language to text translation.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "windows"
  ],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "model/*",
        "mediapipe/*",
        "tfjs/*",
        "permission.html",
        "permission.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}